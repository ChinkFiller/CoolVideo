<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.video.admin.mapper.UpdaterLogMapper">

    <resultMap type="com.ruoyi.video.domain.UpdaterLog" id="UpdaterLogResult">
        <result property="id"    column="id"    />
        <result property="message"    column="message"    />
        <result property="time"    column="time"    />
    </resultMap>

    <sql id="selectUpdaterLogVo">
        select id, message, time from cv_updater_log
    </sql>

    <select id="selectUpdaterLogList" parameterType="com.ruoyi.video.domain.UpdaterLog" resultMap="UpdaterLogResult">
        <include refid="selectUpdaterLogVo"/>
        <where>
            <if test="message != null  and message != ''"> and message = #{message}</if>
            <if test="time != null "> and time = #{time}</if>
        </where>
    </select>

    <select id="selectUpdaterLogById" parameterType="java.lang.String" resultMap="UpdaterLogResult">
        <include refid="selectUpdaterLogVo"/>
        where id = #{id}
    </select>

    <insert id="insertUpdaterLog" parameterType="com.ruoyi.video.domain.UpdaterLog" useGeneratedKeys="true" keyProperty="id">
        insert into cv_updater_log
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="message != null">message,</if>
            <if test="time != null">time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="message != null">#{message},</if>
            <if test="time != null">#{time},</if>
        </trim>
    </insert>

    <update id="updateUpdaterLog" parameterType="com.ruoyi.video.domain.UpdaterLog">
        update cv_updater_log
        <trim prefix="SET" suffixOverrides=",">
            <if test="message != null">message = #{message},</if>
            <if test="time != null">time = #{time},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteUpdaterLogById" parameterType="java.lang.String">
        delete from cv_updater_log where id = #{id}
    </delete>

    <delete id="deleteUpdaterLogByIds" parameterType="java.lang.String">
        delete from cv_updater_log where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <delete id="deleteAllUpdaterLog">
        delete from cv_updater_log
    </delete>
</mapper>
